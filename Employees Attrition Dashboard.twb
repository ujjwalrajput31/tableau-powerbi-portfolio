      <column datatype='string' name='[Attrition]' role='dimension' type='nominal' />
      <column caption='CF attrition label' datatype='string' name='[CF_attrition label]' role='dimension' type='nominal' />
      <column caption='CF current Employee' datatype='integer' name='[CF_current Employee]' role='measure' type='quantitative' />
      <column caption='Average Employees' datatype='real' name='[Calculation_1465652567703554]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Employee Count]+ [CF_current Employee]/2' />
      </column>
      <column caption='YearsInCompany' datatype='string' name='[Calculation_1465652572753925]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Years At Company] &lt;= 10 THEN &quot;1-10&quot;&#13;&#10;ELSEIF [Years At Company] &lt;= 20 THEN &quot;11-20&quot;&#13;&#10;ELSEIF [Years At Company] &lt;= 30 THEN &quot;21-30&quot;&#13;&#10;ELSE &quot;&gt;30&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Band' datatype='string' name='[Calculation_1465652574781446]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 20 THEN &quot;Less than 20&quot;&#13;&#10;ELSEIF [Age] &lt;= 29 THEN &quot;20-29&quot;&#13;&#10;ELSEIF [Age] &lt;= 39 THEN &quot;30-39&quot;&#13;&#10;ELSEIF [Age] &lt;= 49 THEN &quot;40-49&quot;&#13;&#10;ELSEIF [Age] &lt;= 59 THEN &quot;50-59&quot;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;END' />
      </column>
      <column caption='Distance' datatype='string' name='[Calculation_1465652576755719]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Distance From Home] &lt;= 10 THEN &quot;Nearby&quot;&#13;&#10;ELSEIF [Distance From Home] &lt;= 15 THEN &quot;Far&quot;&#13;&#10;ELSE &quot;Very Far&quot;&#13;&#10;END' />
      </column>
      <column caption='Attrition Rate' datatype='real' name='[Calculation_1465652645560338]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Attrition] = &quot;Yes&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([Employee Count])&#13;&#10;* 100' />
      </column>
